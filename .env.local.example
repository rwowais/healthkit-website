# Copy to .env.local (local) and add the same two vars in Vercel →
# Project → Settings → Environment Variables. Both are PUBLIC client
# values (safe to expose). NEVER add the service_role / secret key.
#
# Without these, the app runs exactly as today (local-only, no accounts).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Stripe Payment Links (no backend, no secret keys). Until at
# least one is set, billing is inert and the app stays on the free plan.
# Create them at dashboard.stripe.com → Payment Links, then paste the URLs.
# NEXT_PUBLIC_STRIPE_CHECKOUT_ANNUAL=
# NEXT_PUBLIC_STRIPE_CHECKOUT_MONTHLY=
# NEXT_PUBLIC_STRIPE_CHECKOUT_LIFETIME=
