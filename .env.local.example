# Copy to .env.local (local) and add the same two vars in Vercel →
# Project → Settings → Environment Variables. Both are PUBLIC client
# values (safe to expose). NEVER add the service_role / secret key.
#
# Without these, the app runs exactly as today (local-only, no accounts).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
